{
  "manifest_version": 3,
  "name": "Contexa",
  "version": "0.2.0",
  "description": "Design. Explain. Deliver.",
  "permissions": ["activeTab", "sidePanel", "storage", "scripting"],
  "optional_host_permissions": ["*://*/*"],
  "action": {
    "default_title": "Contexa",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "js": ["i18n.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
